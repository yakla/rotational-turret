(kicad_pcb
  (version 20231120)
  (generator "pcbnew")
  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (title_block
    (title "Rotational Turret PCB")
    (rev "1.0")
    (company "Hackclub Blueprint")
  )
  (layers
    (0  "F.Cu"   signal)
    (31 "B.Cu"   signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask"  user)
    (39 "F.Mask"  user)
    (40 "Dwgs.User" user "User.Drawings")
    (41 "Cmts.User" user "User.Comments")
    (42 "Eco1.User" user "User.Eco1")
    (43 "Eco2.User" user "User.Eco2")
    (44 "Edge.Cuts" user)
    (45 "Margin"    user)
    (46 "B.CrtYd"   user "B.Courtyard")
    (47 "F.CrtYd"   user "F.Courtyard")
    (48 "B.Fab"     user)
    (49 "F.Fab"     user)
  )
  (setup
    (pad_to_mask_clearance 0)
    (allow_soldermask_bridges_in_footprints no)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (outputdirectory "gerbers/")
      (usegerberextensions no)
      (usegerberattributes yes)
      (usegerberadvancedattributes yes)
      (creategerberjobfile yes)
      (svguseinch no)
      (svgprecision 4)
      (excludeedgelayer yes)
      (plotframeref no)
      (viasonmask no)
      (mode 1)
      (useauxorigin no)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15.000000)
      (dxfpolygonmode yes)
      (dxfimperialunits yes)
      (dxfusepcbnewfont yes)
      (psnegative no)
      (psa4output no)
      (plotreference yes)
      (plotvalue yes)
      (plotfptext yes)
      (plotinvisibletext no)
      (sketchpadsonfab no)
      (subtractmaskfromsilk no)
      (outputformat 1)
      (mirror no)
      (drillshape 1)
      (scaleselection 1)
      (outputdirectory "gerbers/")
    )
  )
  (net 0 "")
  (net 1 "VCC")
  (net 2 "GND")
  (net 3 "D1")
  (net 4 "D2")
  (footprint "Module:NodeMCU-v1.0"
    (layer "F.Cu")
    (at 100 100)
    (property "Reference" "U1" (at 0 -18) (layer "F.SilkS") (effects (font (size 1 1))))
    (property "Value" "NodeMCU-v1.0" (at 0 18) (layer "F.Fab") (effects (font (size 1 1))))
    (pad "1" thru_hole circle (at -12.7 -12.7) (size 1.6 1.6) (drill 0.8) (layers "*.Cu" "*.Mask") (net 1 "VCC"))
    (pad "2" thru_hole circle (at -12.7 -10.16) (size 1.6 1.6) (drill 0.8) (layers "*.Cu" "*.Mask") (net 2 "GND"))
    (pad "3" thru_hole circle (at -12.7 -7.62) (size 1.6 1.6) (drill 0.8) (layers "*.Cu" "*.Mask") (net 3 "D1"))
    (pad "4" thru_hole circle (at -12.7 -5.08) (size 1.6 1.6) (drill 0.8) (layers "*.Cu" "*.Mask") (net 4 "D2"))
  )
  (footprint "Connector_PinHeader_2.54mm:PinHeader_1x03_P2.54mm_Vertical"
    (layer "F.Cu")
    (at 130 95)
    (property "Reference" "M1" (at 0 -5) (layer "F.SilkS") (effects (font (size 1 1))))
    (property "Value" "Servo_Pan" (at 0 5) (layer "F.Fab") (effects (font (size 1 1))))
    (pad "1" thru_hole circle (at 0 0) (size 1.7 1.7) (drill 1) (layers "*.Cu" "*.Mask") (net 2 "GND"))
    (pad "2" thru_hole circle (at 2.54 0) (size 1.7 1.7) (drill 1) (layers "*.Cu" "*.Mask") (net 1 "VCC"))
    (pad "3" thru_hole circle (at 5.08 0) (size 1.7 1.7) (drill 1) (layers "*.Cu" "*.Mask") (net 3 "D1"))
  )
  (footprint "Connector_PinHeader_2.54mm:PinHeader_1x03_P2.54mm_Vertical"
    (layer "F.Cu")
    (at 130 110)
    (property "Reference" "M2" (at 0 -5) (layer "F.SilkS") (effects (font (size 1 1))))
    (property "Value" "Servo_Tilt" (at 0 5) (layer "F.Fab") (effects (font (size 1 1))))
    (pad "1" thru_hole circle (at 0 0) (size 1.7 1.7) (drill 1) (layers "*.Cu" "*.Mask") (net 2 "GND"))
    (pad "2" thru_hole circle (at 2.54 0) (size 1.7 1.7) (drill 1) (layers "*.Cu" "*.Mask") (net 1 "VCC"))
    (pad "3" thru_hole circle (at 5.08 0) (size 1.7 1.7) (drill 1) (layers "*.Cu" "*.Mask") (net 4 "D2"))
  )
  (footprint "Connector_PinHeader_2.54mm:PinHeader_1x02_P2.54mm_Vertical"
    (layer "F.Cu")
    (at 85 100)
    (property "Reference" "BT1" (at 0 -5) (layer "F.SilkS") (effects (font (size 1 1))))
    (property "Value" "7.4V_LiPo" (at 0 5) (layer "F.Fab") (effects (font (size 1 1))))
    (pad "1" thru_hole circle (at 0 0) (size 1.7 1.7) (drill 1) (layers "*.Cu" "*.Mask") (net 1 "VCC"))
    (pad "2" thru_hole circle (at 2.54 0) (size 1.7 1.7) (drill 1) (layers "*.Cu" "*.Mask") (net 2 "GND"))
  )
  (segment (start 85 100) (end 100 100) (width 0.25) (layer "F.Cu") (net 1))
  (segment (start 85 102.54) (end 100 102.54) (width 0.25) (layer "F.Cu") (net 2))
  (gr_rect
    (start 75 88)
    (end 145 125)
    (layer "Edge.Cuts")
    (width 0.05)
  )
)
